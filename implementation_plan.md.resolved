### COMMIT 3: PDF Parser + Paragraph Segmenter
**Who**: M2 (Engine) — Backend Lead  
**Time**: Hour 1–2 (11:00 AM – 12:00 PM)  
**Depends on**: Commit 2

**What to build — `backend/services/pdf_parser.py`**:
```python
import pdfplumber
import re
import nltk
nltk.download('punkt_tab', quiet=True)
from nltk.tokenize import sent_tokenize

def extract_text_from_pdf(file_path: str) -> dict:
    """Extract text from PDF and segment into paragraphs with metadata."""
    try:
        with pdfplumber.open(file_path) as pdf:
            full_text = ""
            page_texts = []
            for page in pdf.pages:
                text = page.extract_text() or ""
                full_text += text + "\n"
                page_texts.append(text)
        
        if not full_text.strip():
            return {"error": "PDF contains no extractable text", "paragraphs": [], "references": []}
        
        # Segment into paragraphs
        paragraphs = segment_paragraphs(full_text)
        
        # Extract references
        references = extract_references(full_text)
        
        return {
            "full_text": full_text,
            "paragraphs": paragraphs,
            "references": references,
            "page_count": len(page_texts),
            "total_words": len(full_text.split()),
        }
    except Exception as e:
        return {"error": f"Failed to parse PDF: {str(e)}", "paragraphs": [], "references": []}

def segment_paragraphs(text: str) -> list:
    """Split text into meaningful paragraphs with metadata."""
    # Split on double newlines or significant whitespace gaps
    raw_paragraphs = re.split(r'\n\s*\n', text)
    
    paragraphs = []
    for i, para in enumerate(raw_paragraphs):
        clean = para.strip()
        if len(clean) < 20:  # Skip very short fragments (headers, page numbers)
            continue
        
        sentences = sent_tokenize(clean)
        words = clean.split()
        
        paragraphs.append({
            "index": len(paragraphs),
            "text": clean,
            "sentence_count": len(sentences),
            "word_count": len(words),
            "char_count": len(clean),
        })
    
    return paragraphs

def extract_references(text: str) -> list:
    """Extract references/bibliography section from paper text."""
    # Find the references section
    ref_match = re.search(r'(?i)\b(references|bibliography)\b', text)
    if not ref_match:
        return []
    
    ref_text = text[ref_match.start():]
    
    # Try to extract individual references (numbered or bracketed)
    ref_patterns = re.findall(r'\[(\d+)\]\s*(.+?)(?=\[\d+\]|$)', ref_text, re.DOTALL)
    if ref_patterns:
        return [{"id": int(num), "text": text.strip()} for num, text in ref_patterns]
    
    # Fallback: split by newlines
    lines = [l.strip() for l in ref_text.split('\n') if len(l.strip()) > 10]
    return [{"id": i+1, "text": line} for i, line in enumerate(lines[1:])]  # Skip "References" header
```

**Wire into `main.py`**: Update `/api/upload` to call `pdf_parser.extract_text_from_pdf()`

**Commit message**: `feat: PDF parser with paragraph segmentation and reference extraction`

